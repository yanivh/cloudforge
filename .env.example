# Claude Code authentication — choose one:
#
# Option A: Anthropic API key (pay-per-token)
#   Uncomment and fill in:
# ANTHROPIC_API_KEY=sk-ant-...
#
# Option B: Claude.ai subscription (Pro/Max)
#   Leave ANTHROPIC_API_KEY unset. On first run, open a shell in the
#   container and run: claude login
#   Follow the URL it prints, log in in your browser, done.
#   The session token is saved on the EBS volume — login once, persists forever.

GIT_NAME=Your Name
GIT_EMAIL=you@example.com
USE_GPU=false

# AWS — used by start.sh / stop.sh / suspend.sh / resume.sh
# Leave unset to use your AWS CLI default region (aws configure get region)
AWS_REGION=us-east-1

# SSH config block written by start.sh / resume.sh (~/.ssh/config)
SSH_HOST=cloudforge
# SSH_IDENTITY_FILE=~/.ssh/cloudforge.pem
