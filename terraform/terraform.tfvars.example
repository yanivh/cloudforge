env_name         = "default"
region           = "us-east-1"
instance_type    = "t3.large"
key_name         = "my-ec2-key"        # name of your key pair in AWS (without .pem)
data_volume_size = 200                  # GB
use_spot         = true                 # ~70% cheaper; set false for on-demand

# SSH: restrict to known operator IPs only — never open to 0.0.0.0/0
ssh_allowed_cidrs = ["YOUR_OPERATOR_IP/32"]

# Web app: internet-reachable in MVP; tighten as needed
web_allowed_cidrs = ["0.0.0.0/0"]
