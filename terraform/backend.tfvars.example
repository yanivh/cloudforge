# Remote state backend configuration.
# Copy to backend.tfvars (already gitignored via *.tfvars), fill in real values, then run:
#   terraform init -backend-config=backend.tfvars
#
# Pre-requisites (one-time, create manually or via a bootstrap script):
#   aws s3api create-bucket --bucket YOUR_BUCKET --region us-east-1
#   aws s3api put-bucket-versioning --bucket YOUR_BUCKET --versioning-configuration Status=Enabled
#   aws dynamodb create-table --table-name cloudforge-tf-locks \
#     --attribute-definitions AttributeName=LockID,AttributeType=S \
#     --key-schema AttributeName=LockID,KeyType=HASH \
#     --billing-mode PAY_PER_REQUEST

bucket         = "your-tf-state-bucket-name"
key            = "cloudforge/default/terraform.tfstate"
region         = "us-east-1"
dynamodb_table = "cloudforge-tf-locks"
encrypt        = true
